{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Jenkins Plus — DORA Four Key Metrics: Deploy Frequency, Lead Time, Change Failure Rate, MTTR.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "DORA Key Metrics — Current Window",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 3 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Deploy Frequency (deploys/day)",
      "description": "DORA: Elite ≥ 1/day, High ≥ 1/week, Medium ≥ 1/month, Low < 1/month",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "round(sum(rate(jenkins_builds_success_build_count_total{jenkins_job=~\".*deploy.*|.*release.*\"}[24h])) * 86400, 0.1)",
          "legendFormat": "deploys/day",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 3600000 },
              { "color": "green",  "value": 86400000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Lead Time for Changes (p50)",
      "description": "DORA: Elite < 1h, High < 1d, Medium < 1w, Low < 1mo. Measured as build duration p50.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, rate(jenkins_builds_duration_milliseconds_summary_bucket[24h]))",
          "legendFormat": "p50 lead time",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 15 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Change Failure Rate (%)",
      "description": "DORA: Elite 0-15%, High 0-15%, Medium 0-45%, Low 46-60%. Failed / (Success + Failed) builds.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "100 * sum(rate(jenkins_builds_failed_builds_total[24h])) / clamp_min(sum(rate(jenkins_builds_total[24h])), 1)",
          "legendFormat": "failure rate %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3600000 },
              { "color": "red",    "value": 86400000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "MTTR — Mean Time to Recovery (p50)",
      "description": "DORA: Elite < 1h, High < 1d, Medium < 1w, Low > 1w. Approx. from failed-build durations.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, rate(jenkins_builds_duration_milliseconds_summary_bucket{result=\"FAILURE\"}[24h]))",
          "legendFormat": "MTTR p50",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "Deploy Frequency — Time Series",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false, "showPoints": "never", "drawStyle": "bars", "barAlignment": 0 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "id": 5,
      "options": { "legend": { "calcs": ["sum", "mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Deploy Frequency — Successful Deploys / 1h",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum(increase(jenkins_builds_success_build_count_total{jenkins_job=~\".*deploy.*|.*release.*\"}[1h]))",
          "legendFormat": "Successful deploys / 1h",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum(increase(jenkins_builds_failed_builds_total{jenkins_job=~\".*deploy.*|.*release.*\"}[1h]))",
          "legendFormat": "Failed deploys / 1h",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "title": "Lead Time — Build Duration Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": false, "showPoints": "never" },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Lead Time for Changes — p50, p90, p99",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, rate(jenkins_builds_duration_milliseconds_summary_bucket[30m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.90, rate(jenkins_builds_duration_milliseconds_summary_bucket[30m]))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.99, rate(jenkins_builds_duration_milliseconds_summary_bucket[30m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Change Failure Rate & MTTR — Time Series",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false, "showPoints": "never" },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Change Failure Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "100 * sum(rate(jenkins_builds_failed_builds_total[30m])) / clamp_min(sum(rate(jenkins_builds_total[30m])), 0.001)",
          "legendFormat": "Failure rate %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false, "showPoints": "never" },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "MTTR — Time to Recovery (p50 / p90)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.50, rate(jenkins_builds_duration_milliseconds_summary_bucket{result=\"FAILURE\"}[30m]))",
          "legendFormat": "MTTR p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.90, rate(jenkins_builds_duration_milliseconds_summary_bucket{result=\"FAILURE\"}[30m]))",
          "legendFormat": "MTTR p90",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["jenkins", "jenkins-plus", "dora", "devops"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Jenkins Plus — DORA Metrics",
  "uid": "jenkins-plus-dora",
  "version": 1
}
