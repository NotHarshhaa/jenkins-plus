# ─────────────────────────────────────────────────────────────────────────────
# jenkins-plus — environment variable reference
# Copy this file to .env and fill in your values before running `make dev`.
# Lines starting with # are comments. Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Jenkins Core ──────────────────────────────────────────────────────────────
# Admin account used for local development and as an escape-hatch when OIDC is unavailable.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@example.com

# Public URL Jenkins is reachable at (used in JCasC + email footers).
JENKINS_URL=http://localhost:8080

# Custom banner shown on the Jenkins dashboard.
JENKINS_SYSTEM_MESSAGE=Welcome to jenkins-plus

# ── OIDC / SSO (auto-detects security realm) ───────────────────────────────────
# When OIDC_ISSUER is set: Jenkins uses OIDC SSO (production mode)
# When OIDC_ISSUER is empty: Jenkins uses local accounts (development mode)
# Well-known issuer URL, e.g. https://accounts.google.com or https://login.microsoftonline.com/<tenant>
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── GitHub ────────────────────────────────────────────────────────────────────
# GitHub App credentials (used for org scanning + status checks).
GITHUB_APP_ID=
# Multi-line PEM key — wrap in double-quotes or use a secret manager.
GITHUB_APP_PRIVATE_KEY=
# GitHub organisation / user to scan for Jenkinsfiles.
GITHUB_ORG=

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# ── Kubernetes agents ─────────────────────────────────────────────────────────
# API server URL — use https://kubernetes.default.svc inside cluster.
KUBE_API_URL=https://kubernetes.default
JENKINS_NAMESPACE=jenkins

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_URL=
VAULT_ADDR=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_TEAM_DOMAIN=
SLACK_TOKEN=
SLACK_DEFAULT_CHANNEL=#ci-builds

# ── SonarQube ─────────────────────────────────────────────────────────────────
SONAR_URL=http://sonarqube:9000
SONAR_TOKEN=

# ── Docker registry ───────────────────────────────────────────────────────────
DOCKER_REGISTRY_URL=registry.example.com
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASSWORD=

# ── SSH deployment ───────────────────────────────────────────────────────────
DEPLOY_SSH_USER=deploy
DEPLOY_SSH_KEY=

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25

# ── Observability ─────────────────────────────────────────────────────────────
# OTLP collector endpoint for OpenTelemetry traces + metrics.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
JAEGER_URL=http://jaeger:16686

# ── Shared library ────────────────────────────────────────────────────────────
# Override to point at an external SCM repo; leave blank to use the bundled copy.
SHARED_LIB_REPO=
SHARED_LIB_BRANCH=main

# ── Seed job ──────────────────────────────────────────────────────────────────
SEED_JOB_REPO=
SEED_JOB_BRANCH=main

# ── Static agent (docker-compose only) ───────────────────────────────────────
# Set to the agent secret from Jenkins after the first boot.
JENKINS_AGENT_NAME=docker-agent
JENKINS_AGENT_SECRET=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Next.js UI ────────────────────────────────────────────────────────────────
# These are baked into the browser bundle — do not put secrets here.
NEXT_PUBLIC_JENKINS_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=jenkins-plus
